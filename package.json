{
  "name": "prism-agent-desktop",
  "private": true,
  "version": "0.5.5",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "agent-sidecar",
    "web"
  ],
  "scripts": {
    "dev": "node scripts/dev-desktop.mjs",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "tauri:dev": "node scripts/dev-desktop.mjs",
    "build:web": "bun run --filter prism-web build",
    "build:sidecar": "bun run --filter @prism/agent-sidecar build",
    "build": "bun run build:web && bun run build:sidecar && bun tauri build",
    "tauri:build": "bun run build"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2.3.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1"
  }
}
